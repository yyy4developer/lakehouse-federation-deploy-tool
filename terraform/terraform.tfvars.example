# =============================================================================
# Lakehouse Federation Demo - Configuration
#
# This file is auto-generated by deploy.py.
# To manually configure, copy and edit:
#   cp terraform.tfvars.example terraform.tfvars
# =============================================================================

# --- General ---
project_prefix = "lhf-demo"
cloud          = "aws"  # "aws" or "azure"

# --- Federation Source Toggles ---
enable_glue     = true
enable_redshift = true
enable_postgres = false
enable_synapse  = false
enable_bigquery = false
enable_onelake  = false

# --- Catalog Naming ---
catalog_prefix_query   = "lhf_query"
catalog_prefix_catalog = "lhf_catalog"

# --- Databricks (OAuth U2M via CLI) ---
# Run: databricks auth login --host <workspace-url>
databricks_host = "https://fevm-xxx.cloud.databricks.com"

# --- AWS ---
aws_region              = "us-west-2"
redshift_admin_password = "ChangeMe123!"  # Required if enable_redshift = true

# --- PostgreSQL ---
postgres_admin_password = "PgPass123!"    # Required if enable_postgres = true

# --- Azure (required if any Azure source enabled) ---
# azure_subscription_id    = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# azure_region             = "eastus"
# azure_resource_group_name = "lhf-demo-rg"
# synapse_admin_password   = "SynapsePass123!"

# --- GCP (required if enable_bigquery = true) ---
# gcp_project_id       = "my-gcp-project"
# gcp_region           = "us-central1"
# gcp_credentials_json = ""  # SA key JSON or leave empty for gcloud auth

# --- OneLake (required if enable_onelake = true) ---
# fabric_workspace_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
